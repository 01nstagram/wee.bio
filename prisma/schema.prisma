generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum LinkType {
  WEBSITE
  DISCORD
  GITHUB
  INSTAGRAM
  TWITTER
  YOUTUBE
  TWITCH
  TIKTOK
  SPOTIFY
  EMAIL
  CUSTOM
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  apiKeys       ApiKey[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Profile {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  userId           String         @unique @db.ObjectId
  username         String         @unique
  displayName      String
  bio              String?
  avatarUrl        String?
  bannerUrl        String?
  backgroundUrl    String?
  primaryColor     String         @default("#8b5cf6")
  secondaryColor   String         @default("#22d3ee")
  textColor        String         @default("#ffffff")
  accentStyle      String         @default("glass")
  musicUrl         String?
  embedTitle       String?
  embedDescription String?
  isPublic         Boolean        @default(true)
  showDiscord      Boolean        @default(true)
  links            Link[]
  views            ProfileView[]
  badges           ProfileBadge[]
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Link {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  profileId String   @db.ObjectId
  title     String
  url       String
  type      LinkType @default(CUSTOM)
  icon      String?
  position  Int      @default(0)
  enabled   Boolean  @default(true)
  clicks    Int      @default(0)
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId, position])
}

model Badge {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  name        String         @unique
  label       String
  color       String         @default("#8b5cf6")
  description String?
  profiles    ProfileBadge[]
  createdAt   DateTime       @default(now())
}

model ProfileBadge {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  profileId String  @db.ObjectId
  badgeId   String  @db.ObjectId
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  badge     Badge   @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([profileId, badgeId])
}

model ProfileView {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  profileId String   @db.ObjectId
  ipHash    String?
  referrer  String?
  userAgent String?
  country   String?
  device    String?
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([profileId, createdAt])
}

model ApiKey {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  userId     String    @db.ObjectId
  label      String
  prefix     String    @unique
  keyHash    String    @unique
  scopes     String    @default("profile:read")
  lastUsedAt DateTime?
  revokedAt  DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())

  @@index([userId])
}
